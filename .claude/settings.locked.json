{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(find .:*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git remote set-url*)",
      "Bash(git remote add*)",
      "Bash(curl*host.docker.internal*)",
      "Bash(wget*host.docker.internal*)",
      "Bash(iptables*)",
      "Bash(ipset*)",
      "Bash(sudo*)",
      "Read(.devcontainer/**)",
      "Write(.devcontainer/**)",
      "Edit(.devcontainer/**)"
    ]
  }
}
