{
  "permissions": {
    "allow": [
      "Bash(git push*)",
      "Bash(git status)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(sudo *)",
      "Bash(find .:*)",
      "WebSearch",
      "Read(.devcontainer/**)",
      "Write(.devcontainer/**)",
      "Edit(.devcontainer/**)"
    ],
    "deny": [
      "Bash(git remote set-url*)",
      "Bash(git remote add*)",
      "Bash(git remote -v*)",
      "Bash(git config --get*)",
      "Bash(git config -l*)",
      "Bash(git config --list*)",
      "Bash(curl*host.docker.internal*)",
      "Bash(wget*host.docker.internal*)",
      "Bash(iptables*)",
      "Bash(ipset*)"
    ]
  }
}
